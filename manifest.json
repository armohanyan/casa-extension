{
    "manifest_version": 3,
    "name": "Casa Helper",
    "description": "List.am-ից տվյալների հավաքում և ուղարկում Թելեգրամ կամ CRM",
    "version": "1.1",
    "icons": {
        "16": "icons/icon128.png",
        "48": "icons/icon128.png",
        "128": "icons/icon128.png"
    },
    "permissions": [
        "storage",
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "https://tg.sandia.site/*",
        "https://www.list.am/*",
        "https://*.list.am/*",
        "https://*/*"
    ],
    "action": {
        "default_title": "Տվյալներ Թելեգրամ / CRM",
        "default_icon": {
            "16": "icons/icon128.png",
            "32": "icons/icon128.png",
            "48": "icons/icon128.png"
        },
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "https://*.list.am/item/*"
            ],
            "run_at": "document_idle",
            "js": ["content_script.js"]
        }
    ],
    "background": {
        "service_worker": "background.js"
    }
}